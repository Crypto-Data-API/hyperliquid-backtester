# --- Your strategies stay yours -------------------------------------------
# Everything you or your AI agent drops in strategies/user/ is ignored by
# default, so generated alpha never lands in a commit or a public fork.
strategies/user/*
!strategies/user/.gitkeep
!strategies/user/README.md

# Market data + results are large and reproducible — sync them, don't commit them.
data/
results/
*.parquet

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Secrets --------------------------------------------------------------
.env
.env.local

# --- Editors / OS ---------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
